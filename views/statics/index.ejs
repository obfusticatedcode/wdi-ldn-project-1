<%# Hero %>
<section class="relative bg-gradient-to-br from-brand-800 via-brand-700 to-brand-600 overflow-hidden">
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-0 left-0 w-96 h-96 bg-white rounded-full -translate-x-1/2 -translate-y-1/2"></div>
    <div class="absolute bottom-0 right-0 w-64 h-64 bg-white rounded-full translate-x-1/3 translate-y-1/3"></div>
  </div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
    <div class="max-w-2xl">
      <span class="inline-flex items-center gap-2 bg-white/20 text-white text-xs font-semibold px-3 py-1.5 rounded-full mb-6">
        <i class="fa-solid fa-location-dot"></i>
        Powered by Google Plus Codes. Works anywhere on earth.
      </span>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-tight mb-6">
        Buy &amp; sell locally,<br>
        <span class="text-brand-200">anywhere.</span>
      </h1>
      <p class="text-lg text-brand-100 mb-10 leading-relaxed max-w-xl">
        The marketplace for the 75% of the world without a formal address. No street name? No postcode? No problem. Every location on earth has a Plus Code.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/posts" class="inline-flex items-center justify-center gap-2 bg-white text-brand-700 font-semibold px-6 py-3 rounded-xl hover:bg-brand-50 transition-colors shadow-lg">
          <i class="fa-solid fa-magnifying-glass"></i>
          Browse listings
        </a>
        <% if (locals.isAuthenticated) { %>
          <a href="/posts/new" class="inline-flex items-center justify-center gap-2 bg-brand-900/40 text-white font-semibold px-6 py-3 rounded-xl border border-white/30 hover:bg-brand-900/60 transition-colors backdrop-blur">
            <i class="fa-solid fa-plus"></i>
            Post for free
          </a>
        <% } else { %>
          <a href="/register" class="inline-flex items-center justify-center gap-2 bg-brand-900/40 text-white font-semibold px-6 py-3 rounded-xl border border-white/30 hover:bg-brand-900/60 transition-colors backdrop-blur">
            <i class="fa-solid fa-user-plus"></i>
            Start selling free
          </a>
        <% } %>
      </div>
    </div>
  </div>
</section>

<%# Feature strip %>
<section class="bg-white border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
      <div class="flex items-start gap-4">
        <div class="w-10 h-10 bg-brand-100 rounded-xl flex items-center justify-center flex-shrink-0">
          <i class="fa-solid fa-earth-africa text-brand-600"></i>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-1">No address? No problem.</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Every square metre on earth has a unique Plus Code. Just drop a pin.</p>
        </div>
      </div>
      <div class="flex items-start gap-4">
        <div class="w-10 h-10 bg-green-100 rounded-xl flex items-center justify-center flex-shrink-0">
          <i class="fa-solid fa-tag text-green-600"></i>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-1">Always free to list.</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Post your items for free. No fees, no subscriptions, no surprises.</p>
        </div>
      </div>
      <div class="flex items-start gap-4">
        <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0">
          <i class="fa-solid fa-coins text-blue-600"></i>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 mb-1">Multi-currency support.</h3>
          <p class="text-sm text-gray-500 leading-relaxed">Prices shown in the seller's currency with live conversion for buyers.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<%# Category browse grid %>
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <div class="flex items-center justify-between mb-8">
    <h2 class="text-2xl font-bold text-gray-900">Browse by category</h2>
    <a href="/posts" class="text-sm font-semibold text-brand-600 hover:text-brand-700 flex items-center gap-1">
      See all <i class="fa-solid fa-arrow-right text-xs"></i>
    </a>
  </div>
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
    <% [
      { label: 'Electronics',       icon: 'fa-mobile-screen',   seed: 'electronics-devices',  color: 'bg-blue-50 text-blue-600' },
      { label: 'Clothes',           icon: 'fa-shirt',           seed: 'fashion-clothing',      color: 'bg-pink-50 text-pink-600' },
      { label: 'Furniture',         icon: 'fa-couch',           seed: 'modern-furniture',      color: 'bg-amber-50 text-amber-600' },
      { label: 'Food',              icon: 'fa-basket-shopping', seed: 'food-market-fresh',     color: 'bg-green-50 text-green-600' },
      { label: 'Cars',              icon: 'fa-car',             seed: 'cars-vehicles',         color: 'bg-red-50 text-red-600' },
      { label: 'Books',             icon: 'fa-book-open',       seed: 'books-reading',         color: 'bg-violet-50 text-violet-600' },
      { label: 'Property',          icon: 'fa-house',           seed: 'property-house',        color: 'bg-teal-50 text-teal-600' },
      { label: 'Health & Beauty',   icon: 'fa-heart-pulse',     seed: 'health-beauty-care',    color: 'bg-rose-50 text-rose-600' },
    ].forEach(cat => { %>
      <a href="/posts?q=<%= cat.label %>"
         class="group relative rounded-2xl overflow-hidden aspect-square shadow-card hover:shadow-card-hover transition-all duration-300">
        <img
          src="https://picsum.photos/seed/<%= cat.seed %>/400/400.jpg"
          alt="<%= cat.label %>"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        >
        <div class="absolute inset-0 bg-gradient-to-t from-gray-900/75 via-gray-900/10 to-transparent"></div>
        <div class="absolute bottom-3 left-3 right-3">
          <div class="flex items-center gap-2">
            <div class="w-7 h-7 bg-white/20 backdrop-blur rounded-lg flex items-center justify-center flex-shrink-0">
              <i class="fa-solid <%= cat.icon %> text-white text-xs"></i>
            </div>
            <span class="font-bold text-white text-sm"><%= cat.label %></span>
          </div>
        </div>
      </a>
    <% }) %>
  </div>
</section>

<%# Safety section %>
<section class="bg-gray-900 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h2 class="text-lg font-bold mb-6 flex items-center gap-2">
      <i class="fa-solid fa-shield-halved text-brand-400"></i>
      Stay safe when trading
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
      <div>
        <h3 class="text-xs font-semibold text-brand-400 uppercase tracking-widest mb-3">Buyers</h3>
        <ul class="space-y-2 text-sm text-gray-300">
          <li class="flex items-start gap-2"><i class="fa-solid fa-check text-brand-400 mt-0.5 flex-shrink-0"></i>Meet in a public place where possible.</li>
          <li class="flex items-start gap-2"><i class="fa-solid fa-check text-brand-400 mt-0.5 flex-shrink-0"></i>Inspect the item before paying.</li>
          <li class="flex items-start gap-2"><i class="fa-solid fa-check text-brand-400 mt-0.5 flex-shrink-0"></i>Ask for receipts on high-value items.</li>
        </ul>
      </div>
      <div>
        <h3 class="text-xs font-semibold text-brand-400 uppercase tracking-widest mb-3">Sellers</h3>
        <ul class="space-y-2 text-sm text-gray-300">
          <li class="flex items-start gap-2"><i class="fa-solid fa-check text-brand-400 mt-0.5 flex-shrink-0"></i>Verify banknotes before handing over goods.</li>
          <li class="flex items-start gap-2"><i class="fa-solid fa-check text-brand-400 mt-0.5 flex-shrink-0"></i>If a buyer overpays and asks for change back, it's a scam.</li>
        </ul>
      </div>
    </div>
  </div>
</section>
