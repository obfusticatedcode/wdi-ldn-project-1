<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

  <%# Header + search %>
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Listings</h1>
      <p class="text-sm text-gray-500 mt-0.5"><%= posts.length %> item<%= posts.length !== 1 ? 's' : '' %> available</p>
    </div>
    <form action="/posts" method="GET" class="flex gap-2 w-full sm:w-auto">
      <div class="relative flex-1 sm:flex-none">
        <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
        <input
          type="text" name="q" value="<%= locals.query || '' %>"
          placeholder="Search listings..."
          class="pl-9 pr-4 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent w-full sm:w-64"
        >
      </div>
      <button type="submit" class="px-4 py-2 bg-brand-600 text-white text-sm font-semibold rounded-xl hover:bg-brand-700 transition-colors flex-shrink-0">
        Search
      </button>
    </form>
  </div>

  <%# Category filter pills %>
  <div class="flex gap-2 overflow-x-auto pb-2 mb-8 scrollbar-hide">
    <% [
      { label: 'All',             q: '' },
      { label: 'Electronics',    q: 'Electronics' },
      { label: 'Clothes',        q: 'Clothes' },
      { label: 'Furniture',      q: 'Furniture' },
      { label: 'Food',           q: 'Food' },
      { label: 'Cars',           q: 'Cars' },
      { label: 'Books',          q: 'Books' },
      { label: 'Property',       q: 'Property' },
      { label: 'Health & Beauty',q: 'Health' },
      { label: 'Other',          q: 'Other' },
    ].forEach(cat => {
      const isActive = (locals.query || '') === cat.q;
    %>
      <a href="/posts<%= cat.q ? '?q=' + cat.q : '' %>"
         class="flex-shrink-0 px-4 py-2 rounded-full text-sm font-semibold transition-all
                <%= isActive ? 'bg-brand-600 text-white shadow-sm' : 'bg-white text-gray-600 border border-gray-200 hover:border-brand-400 hover:text-brand-600' %>">
        <%= cat.label %>
      </a>
    <% }) %>
  </div>

  <% if (posts.length === 0) { %>
    <div class="text-center py-24">
      <div class="w-16 h-16 bg-gray-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
        <i class="fa-solid fa-box-open text-2xl text-gray-400"></i>
      </div>
      <h3 class="text-lg font-semibold text-gray-900 mb-2">No listings yet</h3>
      <p class="text-gray-500 mb-6">Be the first to post something.</p>
      <% if (locals.isAuthenticated) { %>
        <a href="/posts/new" class="inline-flex items-center gap-2 bg-brand-600 text-white font-semibold px-6 py-3 rounded-xl hover:bg-brand-700 transition-colors">
          <i class="fa-solid fa-plus"></i> Post the first listing
        </a>
      <% } else { %>
        <a href="/register" class="inline-flex items-center gap-2 bg-brand-600 text-white font-semibold px-6 py-3 rounded-xl hover:bg-brand-700 transition-colors">
          Sign up to sell
        </a>
      <% } %>
    </div>
  <% } else { %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% posts.forEach((post) => { %>
        <a href="/posts/<%= post.id %>" class="group bg-white rounded-2xl overflow-hidden shadow-card hover:shadow-card-hover transition-all duration-300 flex flex-col">
          <div class="aspect-[4/3] overflow-hidden bg-gray-100 relative">
            <% if (post.imageSRC) { %>
              <img
                src="<%= post.imageSRC %>"
                alt="<%= post.title %>"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy"
              >
            <% } else { %>
              <div class="w-full h-full flex items-center justify-center">
                <i class="fa-solid fa-image text-4xl text-gray-300"></i>
              </div>
            <% } %>
            <span class="absolute top-3 left-3 bg-white/90 backdrop-blur text-xs font-semibold text-gray-700 px-2.5 py-1 rounded-full">
              <%= post.category %>
            </span>
          </div>
          <div class="p-4 flex flex-col flex-1">
            <h2 class="font-bold text-gray-900 text-base mb-1 truncate group-hover:text-brand-600 transition-colors"><%= post.title %></h2>
            <p class="text-sm text-gray-500 line-clamp-2 mb-3 flex-1"><%= post.description %></p>
            <div class="flex items-center justify-between">
              <span class="text-lg font-bold text-gray-900">
                <span class="text-sm font-normal text-gray-500 mr-1"><%= post.currency %></span><%= post.price %>
              </span>
              <span class="flex items-center gap-1 text-xs text-brand-600 font-mono font-semibold">
                <i class="fa-solid fa-location-dot text-brand-500"></i>
                <%= post.location %>
              </span>
            </div>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>
</div>
